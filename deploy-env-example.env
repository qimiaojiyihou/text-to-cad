# AI 配置（必填）
OPENAI_API_KEY=你的API密钥
OPENAI_BASE_URL=https://api.lkeap.cloud.tencent.com/coding/v3
LLM_MODEL=kimi-k2.5

# 安全密钥（必填，自己编一个长字符串，20位以上）
SECRET_KEY=这里填一个20位以上的随机字符串比如AbC123XyZ789

# 前端调用后端的地址（必填！）
# 无域名时：http://你的服务器公网IP:8000
# 有域名时：https://api.yourdomain.com
VITE_API_BASE=http://你的服务器公网IP:8000
